# ─── App ─────────────────────────────────────────────
ENVIRONMENT=development
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_BYPASS_ENABLED=true
AUTH_BYPASS_EMAIL=dev@local.app
AUTH_BYPASS_USERNAME=dev_bypass
AUTH_BYPASS_SUPERUSER=true

# ─── Database ─────────────────────────────────────────
POSTGRES_USER=vcreator
POSTGRES_PASSWORD=vcreator_secret
POSTGRES_DB=video_creator
DATABASE_URL=postgresql+asyncpg://vcreator:vcreator_secret@localhost:5432/video_creator

# ─── Redis / Celery ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── MinIO / S3 ───────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_ASSETS=assets
MINIO_BUCKET_OUTPUT=output
MINIO_SECURE=false

# ─── ComfyUI / Video engines ───────────────────────────
COMFYUI_URL=http://localhost:8188
COMFYUI_TIMEOUT=180
# auto = Pollinations first (if key) → local AnimateDiff → motion fallback
COMFYUI_ENGINE=auto
AUTO_DOWNLOAD_MODELS=false

# Phase 1: Pollinations true AI video (Veo/Seedance/Wan) — free tier at enter.pollinations.ai
POLLINATIONS_API_KEY=

# Phase 2: local models — run scripts/download-local-models.ps1 (~6 GB, free offline)

# ─── GPU ──────────────────────────────────────────────
GPU_COUNT=1
GPU_VRAM_THRESHOLD_GB=2.0

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20

# ─── Storage ──────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
